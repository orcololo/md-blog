---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import { getLangFromUrl, useTranslations } from '@/i18n/utils'
import Layout from '@/layouts/Layout.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="404" />
  <Breadcrumbs items={[{ label: '404', icon: 'lucide:circle-help' }]} />

  <section
    class="flex flex-col items-center justify-center gap-y-8 py-16 text-center"
  >
    <div class="animate-fade-in-up space-y-4">
      <p class="text-primary text-xs font-medium tracking-widest uppercase">
        Error 404
      </p>
      <h1
        class="text-foreground text-7xl leading-none font-normal tracking-[-0.04em] sm:text-8xl"
      >
        Page not found
      </h1>
      <p
        class="text-muted-foreground mx-auto max-w-sm text-base leading-relaxed"
      >
        {t('404.description')}
      </p>
    </div>
    <div
      class="animate-fade-in-up flex flex-wrap items-center justify-center gap-4"
      style="animation-delay: 150ms"
    >
      <Link href="/" class={buttonVariants({ variant: 'default' })}>
        <span class="transition-transform group-hover:-translate-x-1"
          >&larr;</span
        >
        {t('404.backHome')}
      </Link>
      <Link href="/blog" class={buttonVariants({ variant: 'outline' })}>
        {t('404.viewBlog')}
      </Link>
    </div>
  </section>
</Layout>
