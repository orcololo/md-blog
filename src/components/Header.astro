---
import LanguageSwitcher from '@/components/LanguageSwitcher.astro'
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { SITE, getNavLinks } from '@/consts'
import { getLangFromUrl, getLocalePath } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const navLinks = getNavLinks(lang)
---

<div>
  <div
    class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link
      href={getLocalePath('/', lang)}
      class="group flex shrink-0 items-center justify-center gap-2 font-mono"
    >
      <span class="text-primary">&#x25B8;</span>
      <span class="hidden text-sm font-medium min-[400px]:block"
        >{SITE.title}</span
      ><span class="animate-blink text-primary hidden min-[400px]:inline"
        >_</span
      >
    </Link>
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-1 font-mono text-xs sm:text-sm">
        <span class="text-muted-foreground hidden sm:inline">[</span>
        {
          navLinks.map((item, i) => (
            <>
              {i > 0 && <span class="text-muted-foreground/40">|</span>}
              <Link
                href={item.href}
                class="text-muted-foreground hover:text-primary px-1.5 py-0.5 transition-colors"
              >
                {item.label}
              </Link>
            </>
          ))
        }
        <span class="text-muted-foreground hidden sm:inline">]</span>
      </nav>
      <LanguageSwitcher />
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
