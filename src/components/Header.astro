---
import LanguageSwitcher from '@/components/LanguageSwitcher.astro'
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { SITE, getNavLinks } from '@/consts'
import { getLangFromUrl, getLocalePath } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const navLinks = getNavLinks(lang)
---

<div>
  <div
    class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link
      href={getLocalePath('/', lang)}
      class="group flex shrink-0 items-center justify-center gap-2"
    >
      <span
        class="text-primary h-2 w-2 rounded-full transition-transform duration-200 group-hover:scale-125"
        aria-hidden="true"></span>
      <span class="hidden text-sm font-medium tracking-tight min-[400px]:block"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center gap-3">
      <nav class="flex items-center gap-1 text-sm">
        {
          navLinks.map((item) => (
            <Link
              href={item.href}
              class="text-muted-foreground hover:text-foreground hover:bg-muted rounded-[4px] px-3 py-1.5 transition-colors duration-150"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <LanguageSwitcher />
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
