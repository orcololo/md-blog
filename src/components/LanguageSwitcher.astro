---
import Link from '@/components/Link.astro'
import { getLanguageSwitchLabel, getLanguageSwitchPath } from '@/i18n/utils'

const switchPath = getLanguageSwitchPath(Astro.url)
const switchLabel = getLanguageSwitchLabel(Astro.url)
---

<Link
  href={switchPath}
  class="text-muted-foreground hover:text-primary px-1.5 py-0.5 font-mono text-xs transition-colors"
  title={switchLabel === 'PT' ? 'Ver em Português' : 'View in English'}
>
  {switchLabel}
</Link>
