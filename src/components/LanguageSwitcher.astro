---
import { getLanguageSwitchPath, getLanguageSwitchLabel } from '@/i18n/utils'
import Link from '@/components/Link.astro'

const switchPath = getLanguageSwitchPath(Astro.url)
const switchLabel = getLanguageSwitchLabel(Astro.url)
---

<Link
  href={switchPath}
  class="text-muted-foreground hover:text-primary font-mono text-xs transition-colors px-1.5 py-0.5"
  title={switchLabel === 'PT' ? 'Ver em Português' : 'View in English'}
>
  {switchLabel}
</Link>
